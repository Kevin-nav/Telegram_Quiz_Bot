# Application Environment
APP_ENV=development

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Neon Database Connection URL (Asyncpg URL)
# Example: postgresql+asyncpg://user:password@ep-cool-db-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@host/db?sslmode=require

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
ARQ_QUEUE_NAME=adarkwa-bot-background-v2

# Webhook configuration
WEBHOOK_URL=https://your-domain.com
WEBHOOK_SECRET=replace-with-a-long-random-secret

# Sentry DSN (Optional)
SENTRY_DSN=

# Cloudflare R2 (Optional for phase 1 foundation, required later for media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
