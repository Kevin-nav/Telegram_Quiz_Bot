# Application Environment
APP_ENV=development

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Neon Database Connection URL (Asyncpg URL)
# Example: postgresql+asyncpg://user:password@ep-cool-db-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@host/db?sslmode=require

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
ARQ_QUEUE_NAME=adarkwa-bot-background-v2

# Adaptive quiz runtime
# No feature flags are required: adaptive selection and updates are the default path.
# Ensure DATABASE_URL and REDIS_URL point at the same environment used by the bot and worker.

# Webhook configuration
WEBHOOK_URL=https://your-domain.com
WEBHOOK_SECRET=replace-with-a-long-random-secret

# Sentry DSN (Optional)
SENTRY_DSN=

# Admin frontend origins allowed to call the backend admin API
ADMIN_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional parent domain for sharing admin auth cookies across subdomains
# Example: .adarkwa.study
ADMIN_SESSION_COOKIE_DOMAIN=

# Cloudflare R2 (required if your ready questions use rendered image assets such as LaTeX)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
